{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Bid QPS (requests/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(bid_requests_total[1m])",
          "legendFormat": "Total QPS"
        }
      ]
    },
    {
      "title": "Bid vs No-Bid Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2, "stacking": { "mode": "normal" } },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(bid_responses_total{outcome=\"bid\"}[1m])",
          "legendFormat": "Bids"
        },
        {
          "expr": "rate(bid_responses_total{outcome=\"nobid\"}[1m])",
          "legendFormat": "No-Bids"
        },
        {
          "expr": "rate(bid_responses_total{outcome=\"timeout\"}[1m])",
          "legendFormat": "Timeouts"
        },
        {
          "expr": "rate(bid_responses_total{outcome=\"error\"}[1m])",
          "legendFormat": "Errors"
        }
      ]
    },
    {
      "title": "Fill Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.15 },
              { "color": "green", "value": 0.30 }
            ]
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "bid_fill_rate",
          "legendFormat": "Fill Rate"
        }
      ]
    },
    {
      "title": "Latency Percentiles (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 5, "lineWidth": 2 },
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "bid_latency_seconds{quantile=\"0.5\"} * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "bid_latency_seconds{quantile=\"0.9\"} * 1000",
          "legendFormat": "p90"
        },
        {
          "expr": "bid_latency_seconds{quantile=\"0.99\"} * 1000",
          "legendFormat": "p99"
        },
        {
          "expr": "bid_latency_seconds{quantile=\"0.999\"} * 1000",
          "legendFormat": "p99.9"
        }
      ]
    },
    {
      "title": "Error & Timeout Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Timeouts" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(bid_responses_total{outcome=\"error\"}[1m])",
          "legendFormat": "Errors"
        },
        {
          "expr": "rate(bid_responses_total{outcome=\"timeout\"}[1m])",
          "legendFormat": "Timeouts"
        }
      ]
    },
    {
      "title": "Pipeline Stage Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "normal" } },
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pipeline_stage_latency_seconds_sum[1m]) / rate(pipeline_stage_latency_seconds_count[1m]) * 1000",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "title": "Frequency Cap & Budget Hits",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(frequency_cap_hit_total[1m])",
          "legendFormat": "Frequency Cap Hits"
        },
        {
          "expr": "rate(budget_exhausted_total[1m])",
          "legendFormat": "Budget Exhausted"
        }
      ]
    },
    {
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "CLOSED", "color": "green" },
                "1": { "text": "OPEN", "color": "red" },
                "2": { "text": "HALF_OPEN", "color": "yellow" }
              }
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "circuit_breaker_state",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "title": "JVM Memory (Heap)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "jvm_memory_committed_bytes{area=\"heap\"}",
          "legendFormat": "Heap Committed"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "Heap Max"
        }
      ]
    },
    {
      "title": "GC Pause Time (seconds/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 28 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum[1m])",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "title": "GC Pauses/min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 28 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(jvm_gc_pause_seconds_count[1m])",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "title": "No-Bid Reasons (per sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "lineWidth": 1, "stacking": { "mode": "normal" } },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(bid_responses_total{outcome=\"nobid\"}[1m])",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "title": "Event Loop Lag (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 36 },
      "datasource": "Prometheus",
      "description": "Drift between scheduled and actual execution of a 100ms probe on the event loop. Spike = loop was blocked.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "ms"
        },
        "overrides": []
      },
      "targets": [
        { "expr": "event_loop_lag_seconds{quantile=\"0.5\"} * 1000",  "legendFormat": "p50" },
        { "expr": "event_loop_lag_seconds{quantile=\"0.9\"} * 1000",  "legendFormat": "p90" },
        { "expr": "event_loop_lag_seconds{quantile=\"0.99\"} * 1000", "legendFormat": "p99" },
        { "expr": "event_loop_lag_seconds{quantile=\"0.999\"} * 1000","legendFormat": "p99.9" }
      ]
    },
    {
      "title": "BidContext Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 36 },
      "datasource": "Prometheus",
      "description": "If total_created keeps growing after warmup, the pool is undersized and we're allocating on the hot path (Phase 11 regression).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        { "expr": "bid_context_pool_available",     "legendFormat": "available" },
        { "expr": "bid_context_pool_total_created", "legendFormat": "total created (cumulative)" }
      ]
    },
    {
      "title": "CPU Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "percentunit",
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        { "expr": "process_cpu_usage", "legendFormat": "process" },
        { "expr": "system_cpu_usage",  "legendFormat": "system" }
      ]
    },
    {
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        { "expr": "jvm_threads_live_threads",   "legendFormat": "live" },
        { "expr": "jvm_threads_daemon_threads", "legendFormat": "daemon" },
        { "expr": "jvm_threads_peak_threads",   "legendFormat": "peak" }
      ]
    },
    {
      "type": "row",
      "title": "Redis (server-side)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 52 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Redis — Client-side Command Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 53 },
      "datasource": "Prometheus",
      "description": "Bidder-observed Lettuce RTT per Redis command. Different from stage latency (which also counts local work) and server-side (which doesn't include network). Spread tells you whether slowness is client, network, or server.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 5, "lineWidth": 2 }, "unit": "ms" }
      },
      "targets": [
        { "expr": "redis_client_command_duration_seconds{quantile=\"0.5\"}   * 1000", "legendFormat": "{{command}} p50" },
        { "expr": "redis_client_command_duration_seconds{quantile=\"0.99\"}  * 1000", "legendFormat": "{{command}} p99" },
        { "expr": "redis_client_command_duration_seconds{quantile=\"0.999\"} * 1000", "legendFormat": "{{command}} p999" }
      ]
    },
    {
      "title": "Redis — Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 61 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "bytes" }
      },
      "targets": [
        { "expr": "redis_memory_used_bytes",     "legendFormat": "used" },
        { "expr": "redis_memory_max_bytes != 0", "legendFormat": "max" }
      ]
    },
    {
      "title": "Redis — Connected Clients",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 61 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" }
      },
      "targets": [
        { "expr": "redis_connected_clients", "legendFormat": "clients" }
      ]
    },
    {
      "title": "Redis — Ops/sec by command",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 61 },
      "datasource": "Prometheus",
      "description": "Per-command rate — shows whether traffic is dominated by SMEMBERS (segments), INCR (freq cap), or DECRBY (budget)",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" }
      },
      "targets": [
        { "expr": "rate(redis_commands_total[1m])", "legendFormat": "{{cmd}}" }
      ]
    },
    {
      "title": "Redis — Keyspace Hits vs Misses",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 69 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" }
      },
      "targets": [
        { "expr": "rate(redis_keyspace_hits_total[1m])",   "legendFormat": "hits/sec" },
        { "expr": "rate(redis_keyspace_misses_total[1m])", "legendFormat": "misses/sec" }
      ]
    },
    {
      "title": "Redis — Evictions & Expirations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 69 },
      "datasource": "Prometheus",
      "description": "Evictions climbing means Redis is out of memory and dropping data — data loss event.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" }
      },
      "targets": [
        { "expr": "rate(redis_evicted_keys_total[1m])", "legendFormat": "evictions/sec" },
        { "expr": "rate(redis_expired_keys_total[1m])", "legendFormat": "expirations/sec" }
      ]
    },
    {
      "type": "row",
      "title": "Kafka (broker-side)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 77 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Kafka — Messages In/sec per topic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 78 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" }
      },
      "targets": [
        { "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset[1m]))", "legendFormat": "{{topic}}" }
      ]
    },
    {
      "title": "Kafka — Consumer Group Lag (messages)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 78 },
      "datasource": "Prometheus",
      "description": "Lag growing = consumers falling behind producers — events pile up in Kafka.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" }
      },
      "targets": [
        { "expr": "sum by (consumergroup, topic) (kafka_consumergroup_lag)", "legendFormat": "{{consumergroup}} / {{topic}}" }
      ]
    },
    {
      "title": "Kafka — Log End Offset per topic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 86 },
      "datasource": "Prometheus",
      "description": "Cumulative messages ever produced per topic — flat line = no events flowing.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" }
      },
      "targets": [
        { "expr": "sum by (topic) (kafka_topic_partition_current_offset)", "legendFormat": "{{topic}}" }
      ]
    },
    {
      "title": "Kafka — Under-replicated Partitions",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 86 },
      "datasource": "Prometheus",
      "description": "Should always be 0 in a healthy cluster. Non-zero = broker failure or replication lag.",
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } }
      },
      "targets": [
        { "expr": "kafka_topic_partition_under_replicated_partition", "legendFormat": "{{topic}}/{{partition}}" }
      ]
    },
    {
      "type": "row",
      "title": "PostgreSQL",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 94 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "PG — Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 95 },
      "datasource": "Prometheus",
      "description": "Climbing = connection leak. Flat near max = pool saturation, new queries will wait.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" }
      },
      "targets": [
        { "expr": "pg_stat_database_numbackends{datname=\"rtb\"}", "legendFormat": "active" },
        { "expr": "pg_settings_max_connections",                    "legendFormat": "max" }
      ]
    },
    {
      "title": "PG — Transactions/sec (commits & rollbacks)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 95 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" }
      },
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit{datname=\"rtb\"}[1m])",   "legendFormat": "commits/sec" },
        { "expr": "rate(pg_stat_database_xact_rollback{datname=\"rtb\"}[1m])", "legendFormat": "rollbacks/sec" }
      ]
    },
    {
      "title": "PG — Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 95 },
      "datasource": "Prometheus",
      "description": "Healthy is >99%. Lower means queries hitting disk — latency spikes likely.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.99 }] }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_blks_hit{datname=\"rtb\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{datname=\"rtb\"}[5m])) + sum(rate(pg_stat_database_blks_read{datname=\"rtb\"}[5m])))",
          "legendFormat": "cache hit ratio"
        }
      ]
    },
    {
      "type": "row",
      "title": "Containers (cAdvisor)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 103 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Per-Container CPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 104 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "percentunit" }
      },
      "targets": [
        { "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\"}[1m]))", "legendFormat": "{{name}}" }
      ]
    },
    {
      "title": "Per-Container Memory (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 104 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "bytes" }
      },
      "targets": [
        { "expr": "container_memory_rss{name!=\"\"}", "legendFormat": "{{name}}" }
      ]
    },
    {
      "title": "Per-Container Network RX",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 112 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2 }, "unit": "Bps" }
      },
      "targets": [
        { "expr": "sum by (name) (rate(container_network_receive_bytes_total{name!=\"\"}[1m]))", "legendFormat": "{{name}}" }
      ]
    },
    {
