# ── Server ──
SERVER_PORT=8080
SERVER_BASEURL=http://localhost:8080
SERVER_BODY_MAXSIZE=65536

# ── Pipeline ──
PIPELINE_SLA_MAXLATENCYMS=50

# ── Redis ──
REDIS_URI=redis://localhost:6379
REDIS_COMMAND_TIMEOUT_MS=50
REDIS_CONNECT_TIMEOUT_MS=2000

# ── Campaigns ──
CAMPAIGNS_SOURCE=json
# CAMPAIGNS_SOURCE=postgres

# ── PostgreSQL (when CAMPAIGNS_SOURCE=postgres) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=rtb
POSTGRES_USER=rtb
POSTGRES_PASSWORD=rtb

# ── Targeting ──
TARGETING_TYPE=segment
TARGETING_EMBEDDING_CAMPAIGN_PATH=ml/campaign_embeddings.json
TARGETING_EMBEDDING_WORD_PATH=ml/word_embeddings.json
TARGETING_EMBEDDING_THRESHOLD=0.3

# ── Scoring ──
SCORING_TYPE=feature-weighted
SCORING_ML_MODEL_PATH=ml/pctr_model.onnx
SCORING_ML_SCHEMA_PATH=ml/feature_schema.json
SCORING_ABTEST_TREATMENT_PERCENTAGE=50
SCORING_CASCADE_THRESHOLD=0.1

# ── Budget Pacing ──
PACING_TYPE=local
PACING_HOURLY_ENABLED=false
PACING_HOURLY_HOURS=24

# ── Resilience ──
RESILIENCE_REDIS_FAILURE_THRESHOLD=5
RESILIENCE_REDIS_COOLDOWN_MS=10000
RESILIENCE_KAFKA_FAILURE_THRESHOLD=5
RESILIENCE_KAFKA_COOLDOWN_MS=30000

# ── Events ──
EVENTS_TYPE=noop

# ── Kafka (when EVENTS_TYPE=kafka) ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_BID_EVENTS=bid-events
KAFKA_TOPIC_WIN_EVENTS=win-events
KAFKA_TOPIC_IMPRESSION_EVENTS=impression-events
KAFKA_TOPIC_CLICK_EVENTS=click-events

# ── Logging ──
LOG_DIR=logs
CONSOLE_ENABLED=true
FILE_ENABLED=true
JSON_ENABLED=true

# ── Grafana (dev defaults — override for non-local use) ──
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
