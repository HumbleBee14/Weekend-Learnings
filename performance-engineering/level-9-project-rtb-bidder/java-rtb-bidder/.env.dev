# ─────────────────────────────────────────────────────────────────────────────
# NO confidential secrets in this file — configuration values only.
# Safe to commit. Copy to `.env` (gitignored) and edit if you need local
# overrides without changing the committed defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ──
SERVER_PORT=8080
SERVER_BASEURL=http://localhost:8080
SERVER_BODY_MAXSIZE=65536

# ── Pipeline ──
PIPELINE_SLA_MAXLATENCYMS=50

# Candidate truncation BEFORE scoring — top-N by value_per_click (min-heap, O(N log K)).
# 0 = unlimited; 32 = current default; lower = stricter latency budget, less bid quality.
PIPELINE_CANDIDATES_MAX=32

# ── Redis ──
REDIS_URI=redis://localhost:6379
REDIS_COMMAND_TIMEOUT_MS=50
REDIS_CONNECT_TIMEOUT_MS=2000
# How many parallel Lettuce connections per Redis client (round-robin distributed).
# Each connection gets its own nioEventLoop decoder thread.
#   4 (default) — sweet spot on this 12-core Mac. Tested.
#   8 — tested, made things WORSE: 24 total Lettuce nio threads × 72 Vert.x workers
#       on 12 perf cores → context-switching dominates. Bid_rate at 25K dropped
#       16.46% → 1.84%. Reverted.
REDIS_POOL_SIZE=4

# ── Frequency-cap store ──
# redis (default) | aerospike — when aerospike, run: docker-compose --profile aerospike up -d
FREQCAP_STORE=redis

# ── Aerospike (only used when FREQCAP_STORE=aerospike) ──
AEROSPIKE_HOST=localhost
AEROSPIKE_PORT=3500
AEROSPIKE_NAMESPACE=rtb
AEROSPIKE_SET=freq
AEROSPIKE_CONNECT_TIMEOUT_MS=2000
AEROSPIKE_COMMAND_TIMEOUT_MS=50
AEROSPIKE_EVENTLOOP_SIZE=16

# ── Campaigns ──
# json     — load from src/main/resources/campaigns.json (small fixture set)
# postgres — load from the postgres container (1000-campaign realistic catalog)
CAMPAIGNS_SOURCE=postgres

# ── PostgreSQL (when CAMPAIGNS_SOURCE=postgres) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=rtb
POSTGRES_USER=rtb
POSTGRES_PASSWORD=rtb

# ── Targeting ──
TARGETING_TYPE=segment
TARGETING_EMBEDDING_CAMPAIGN_PATH=ml/campaign_embeddings.json
TARGETING_EMBEDDING_WORD_PATH=ml/word_embeddings.json
TARGETING_EMBEDDING_THRESHOLD=0.3

# ── Scoring ──
# feature-weighted — cheap math: relevance × bidFloor × pacingFactor (microseconds/candidate)
# ml              — ONNX pCTR model on every candidate (milliseconds/candidate; brutal)
# cascade         — feature-weighted pre-filter; ML only on candidates above threshold (production-realistic)
# abtest          — split traffic % between feature-weighted and ml
SCORING_TYPE=feature-weighted
SCORING_ML_MODEL_PATH=ml/pctr_model.onnx
SCORING_ML_SCHEMA_PATH=ml/feature_schema.json
SCORING_ABTEST_TREATMENT_PERCENTAGE=50
SCORING_CASCADE_THRESHOLD=0.5

# ── Budget Pacing ──
PACING_TYPE=local
PACING_HOURLY_ENABLED=false
PACING_HOURLY_HOURS=24

# Quality-based throttling (Phase 15 — needs pCTR scorer for meaningful scores)
PACING_QUALITY_THROTTLING_ENABLED=false
PACING_QUALITY_THRESHOLD_LOW=0.05
PACING_QUALITY_THRESHOLD_HIGH=0.20

# ── Resilience ──
RESILIENCE_REDIS_FAILURE_THRESHOLD=5
RESILIENCE_REDIS_COOLDOWN_MS=10000
RESILIENCE_KAFKA_FAILURE_THRESHOLD=5
RESILIENCE_KAFKA_COOLDOWN_MS=30000

# ── Events ──
# noop  — events are dropped at the publisher boundary; no Kafka traffic
# kafka — every bid/win/click is serialised and produced to Kafka topics (needs Kafka container)
EVENTS_TYPE=noop

# ── Kafka (when EVENTS_TYPE=kafka) ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_BID_EVENTS=bid-events
KAFKA_TOPIC_WIN_EVENTS=win-events
KAFKA_TOPIC_IMPRESSION_EVENTS=impression-events
KAFKA_TOPIC_CLICK_EVENTS=click-events

# ── Logging ──
LOG_DIR=logs
CONSOLE_ENABLED=true
FILE_ENABLED=true
JSON_ENABLED=true

# ── Grafana (dev defaults — override for non-local use) ──
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
